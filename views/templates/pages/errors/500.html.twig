{% extends "@ModuleAutoUpgrade/layouts/error.html.twig" %}

{% block title %}
  <h2 class="error-page__title">
    {{ 'Something went wrong...'|trans({}) }}
  </h2>
{% endblock %}

{% block description %}
  <p class="error-page__desc">
    {{ 'The module is no longer responding. You can try again in a few moments.'|trans({}) }}
  </p>
{% endblock %}

{% block button %}
  <a class="error-page__button btn btn-default btn-lg" href="#">
    {{ 'Send error report'|trans({}) }}
  </a>

  <a class="error-page__button btn btn-primary btn-lg" href="#">
    {{ 'Go back to Update assistant'|trans({}) }}
  </a>
{% endblock %}
